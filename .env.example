NODE_ENV=development
TRADING_MODE=paper
BOOT_BLOCK_ON_ORPHAN_POSITIONS=false
PAPER_BALANCE=10000
PAPER_MARKET_ENTRY=true
PAPER_SIDE=buy
PAPER_BYPASS_SCORE=true

DELTA_API_KEY=your_key_here
DELTA_API_SECRET=your_secret_here

DELTA_BASE_URL=https://api.india.delta.exchange
DELTA_WS_URL=wss://socket.india.delta.exchange

# Optional: product selection (auto-resolve ID if only symbol is set)
DELTA_PRODUCT_SYMBOL=BTCUSD
DELTA_PRODUCT_SYMBOLS=BTCUSD,ETHUSD,XRPUSD,SOLUSD
DELTA_PRODUCT_ID=

LOG_LEVEL=info
FORCE_HTF_BIAS=

# AI veto layer
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen3:latest
OPENAI_MODEL=gpt-4.1-mini

# OpenAI (optional, for AI veto layer)
OPENAI_API_KEY=

# SMC sweep guardrails (documentation-only defaults)
# Sweep expiry and proximity/volume gates are enforced in code.
# No additional environment variables are required.

# SMC bar indexing is timestamp-derived (restart-safe), not session-counter based.

BOOT_CLOSE_ORPHAN_POSITIONS=true

# No additional env vars are required for bracket rollback/cancel-failure logging hardening.
