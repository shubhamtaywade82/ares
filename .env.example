NODE_ENV=development
# paper = simulated execution, live feed. live = real Delta orders. dev = real Delta data + simulated execution, relaxed gates for pipeline testing.
TRADING_MODE=paper
BOOT_BLOCK_ON_ORPHAN_POSITIONS=false
PAPER_BALANCE=10000
PAPER_MARKET_ENTRY=true
PAPER_SIDE=buy
PAPER_BYPASS_SCORE=true
# In paper mode, set to true to allow synthetic displacement so entries fire without rare real SMC displacement (pipeline testing).
PAPER_SYNTHETIC_DISPLACEMENT=false

# Profit target: exit position when margin PnL reaches this % (0.10 = 10%)
PROFIT_TARGET_PCT=0.10

DELTA_API_KEY=your_key_here
DELTA_API_SECRET=your_secret_here

DELTA_BASE_URL=https://api.india.delta.exchange
DELTA_WS_URL=wss://socket.india.delta.exchange

# Optional: product selection (auto-resolve ID if only symbol is set)
# Use DELTA_PRODUCT_SYMBOLS for multiple symbols (dashboard watchlist + strategy).
# If only DELTA_PRODUCT_SYMBOL is set, that single symbol is used.
DELTA_PRODUCT_SYMBOL=BTCUSD
DELTA_PRODUCT_SYMBOLS=BTCUSD,ETHUSD,SOLUSD,XRPUSD
DELTA_PRODUCT_ID=

LOG_LEVEL=info
FORCE_HTF_BIAS=

# AI veto layer
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen3:latest
OPENAI_MODEL=gpt-4.1-mini

# OpenAI (optional, for AI veto layer)
OPENAI_API_KEY=

# SMC aggressiveness tier: aggressive (more trades, less confirmation),
# moderate (balanced), conservative (full SMC sequence required)
SMC_AGGRESSION=moderate

# SMC sweep guardrails (documentation-only defaults)
# Sweep expiry and proximity/volume gates are enforced in code.
# No additional environment variables are required.

# SMC bar indexing is timestamp-derived (restart-safe), not session-counter based.

BOOT_CLOSE_ORPHAN_POSITIONS=true

# No additional env vars are required for bracket rollback/cancel-failure logging hardening.
